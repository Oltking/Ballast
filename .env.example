# Ballast environment — copy to .env and fill in. NEVER commit .env.
# Values tagged [corpus-verified] are confirmed against research/RESEARCH_FULL.md + cloned repos.

STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org           # [corpus-verified]
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015  # [corpus-verified]
FRIENDBOT_URL=https://friendbot.stellar.org                   # [corpus-verified]
HORIZON_URL=https://horizon-testnet.stellar.org              # [corpus-verified]

# Testnet identity — generate with `stellar keys generate`, fund via Friendbot/Lab. Never log.
SOURCE_ACCOUNT_SECRET=

# Reserve asset — testnet stablecoin wrapped as a Stellar Asset Contract (SAC). Record its contract id.
# (DECISION REQUIRED — see README "Open decisions")
RESERVE_ASSET=

# Deployed contract ids (filled in as phases complete)
VERIFIER_CONTRACT_ID=
VAULT_CONTRACT_ID=
IMAGE_ID=

# RISC Zero proving
RISC0_DEV_MODE=0                # real proofs, not dev-mode fakes
BONSAI_API_KEY=                 # optional — remote proving (avoids local Docker/Groth16 on Windows)
BONSAI_API_URL=https://api.bonsai.xyz/
